{
  "name": "dex",
  "version": "0.1.2",
  "description": "Bun-native CLI for AWS, Kubernetes, and GitLab CI/CD workflows.",
  "type": "module",
  "private": true,
  "author": "Andrii Orlov",
  "license": "MIT",
  "homepage": "https://github.com/aaorlov/dex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aaorlov/dex.git"
  },
  "bugs": {
    "url": "https://github.com/aaorlov/dex/issues"
  },
  "keywords": [
    "cli",
    "bun",
    "aws",
    "kubernetes",
    "k8s",
    "gitlab",
    "devops",
    "infrastructure"
  ],
  "bin": {
    "dex": "./src/index.ts"
  },
  "files": ["src", "README.md", "LICENSE"],
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/index.ts --compile --minify --bytecode --format=esm --outfile dist/dex",
    "build:darwin-arm64": "bun build ./src/index.ts --compile --minify --bytecode --format=esm --target=bun-darwin-arm64 --outfile dist/dex-darwin-arm64",
    "build:darwin-x64": "bun build ./src/index.ts --compile --minify --bytecode --format=esm --target=bun-darwin-x64 --outfile dist/dex-darwin-x64",
    "build:linux-x64": "bun build ./src/index.ts --compile --minify --bytecode --format=esm --target=bun-linux-x64 --outfile dist/dex-linux-x64",
    "build:linux-arm64": "bun build ./src/index.ts --compile --minify --bytecode --format=esm --target=bun-linux-arm64 --outfile dist/dex-linux-arm64"
  },
  "dependencies": {
    "@clack/prompts": "1.4.0",
    "commander": "14.0.3",
    "markdansi": "0.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
